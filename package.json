{
  "name": "boilerplate-client",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bunx --bun vite --config config/vite.config.js",
    "build": "vite build --mode production --config config/vite.config.js",
    "deploy": "bun run test && vite build --mode production --config config/vite.config.js -- --deploy",
    "lint": "time eslint --stats --cache --concurrency auto -c ./config/.eslintrc.js src/**/*.ts tests/**/*.test.ts",
    "unit": "bun test",
    "test": "bun run lint && bun run unit"
  },
