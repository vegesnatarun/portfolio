    "@types/jest": "^27.5.1",
    "@types/three": "^0.184.0",
    "chalk": "^5.6.2",
    "eslint": "^9.35.0",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12"
  },
